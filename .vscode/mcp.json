{
    "servers": {
        "shadcn": {
            "command": "npx",
            "args": ["shadcn@latest", "mcp"],
            "type": "stdio"
        },
        "io.github.ChromeDevTools/chrome-devtools-mcp": {
            "command": "npx",
            "args": ["-y", "chrome-devtools-mcp", "--autoConnect"],
            "env": {},
            "type": "stdio"
        },
        "io.github.vercel/next-devtools-mcp": {
            "type": "stdio",
            "command": "npx",
            "args": ["next-devtools-mcp@0.3.6"],
            "gallery": "https://api.mcp.github.com",
            "version": "0.3.6"
        }
    }
}
