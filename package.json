{
    "name": "portfolio",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@10.30.3",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "check": "biome check --write .",
        "commit": "cz",
        "prepare": "husky"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,mjs,json,css}": [
            "biome check --write --no-errors-on-unmatched"
        ]
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "lucide-react": "^1.6.0",
        "next": "16.2.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "tailwind-merge": "^3.5.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.9",
        "@commitlint/cli": "^20.4.3",
        "@commitlint/config-conventional": "^20.4.3",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "babel-plugin-react-compiler": "^1.0.0",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "shadcn": "^4.0.0",
        "tailwindcss": "^4",
        "typescript": "^5"
    }
}
